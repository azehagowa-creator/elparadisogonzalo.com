{
  "name": "@azehagowa-creator/elparadisogonzalo.com",
  "version": "2.0.0",
  "private": true,
  "description": "Elparadisogonzalo Web3 dApp, website, Android app, and APIs",
  "license": "Apache-2.0",
  "author": "Azeh Agowa",
  "homepage": "http://elparadisogonzalo.genyoungclip-0ce.workers.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azehagowa-creator/elparadisogonzalo.com.git"
  },
  "bugs": {
    "url": "https://github.com/azehagowa-creator/elparadisogonzalo.com/issues"
  },
  "keywords": [
    "web3",
    "ethereum",
    "bsc",
    "blockchain",
    "vite",
    "capacitor",
    "android",
    "github-pages",
    "unstoppable-domains"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@12",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "deploy": "wrangler deploy",
    "preview": "npm run preview --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "sync": "npm exec --workspace=frontend cap sync android",
    "android": "npm exec --workspace=frontend cap open android",
    "apk": "cd frontend/android && ./gradlew assembleDebug",
    "release": "cd frontend/android && ./gradlew assembleRelease",
    "bundle": "cd frontend/android && ./gradlew bundleRelease",
    "prepare": "echo Repository ready",
    "test": "echo \"No tests configured\" && exit 0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "openai": "^6.47.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.18.1",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.elparadisogonzalo.com",
    "access": "public"
  }
}
