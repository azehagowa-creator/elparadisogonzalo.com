{
  "name": "elparadisogonzalo-com",
  "version": "1.0.0",
  "public": true,
  "description": "Elparadisogonzalo Web3 dApp and website",
  "license": "Apache-2.0",
  "author": "Azeh Agowa",
  "repository": {
    "type": "git",
    "url": "https://github.com/azehagowa-creator/elparadisogonzalo.com.git"
  },
  "homepage": "https://azehagowa-creator.github.io/elparadisogonzalo.com/",
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "install:frontend": "npm --prefix frontend install",
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview",
    "sync": "npm --prefix frontend exec cap sync android",
    "android": "npm --prefix frontend exec cap open android",
    "apk": "cd frontend/android && ./gradlew assembleDebug",
    "release": "cd frontend/android && ./gradlew assembleRelease"
  }
}
